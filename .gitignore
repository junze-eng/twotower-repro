# experiment outputs (regenerated on the pod)
results/
*.npz
*.gif

# python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# HF cache (should live on the persistent volume, never in the repo)
hf/
*.safetensors

# os / editor
.DS_Store
.ipynb_checkpoints/

# report figures/animations: ALWAYS track figs/ even though *.gif / *.npz are ignored above
# (this is why denoising.gif etc. no longer need `git add -f`)
!figs/
!figs/**
